  "adaptiveRules": [
    {
      "condition": {
        "metric": "accuracy",
        "operator": ">=",
        "value": 0.85
      },
      "action": {
        "type": "adjustDifficulty",
        "payload": {
          "difficulty": "hard"
        }
      }
    },
    {
      "condition": {
        "metric": "accuracy",
        "operator": "<",
        "value": 0.35
      },
      "action": {
        "type": "adjustDifficulty",
        "payload": {
          "difficulty": "easy"
        }
      }
    },
    {
      "condition": {
        "metric": "streak",
        "operator": ">=",
        "value": 5
      },
      "action": {
        "type": "awardBonus",
        "payload": {
          "points": 250
        }
      }
    }
  ],
